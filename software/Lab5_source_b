#include "sys\alt_stdio.h"
#include "system.h"
#include "altera_avalon_pio_regs.h"
#include <time.h>
#include <unistd.h>
#include <sys/alt_alarm.h>

alt_u32 my_alarm_callback (void* context) {
    volatile int* leds_val_ptr = (volatile int*) context; // leds_val_ptr хранит текущее состояние светодиодов
    if ((*leds_val_ptr)==0x80)
    	*leds_val_ptr=0x01;
    else
    	*leds_val_ptr = (*leds_val_ptr) << 1;
    alt_printf("подпрограмма активизирована\n");
    IOWR_ALTERA_AVALON_PIO_DATA(LED_BASE,*leds_val_ptr);
    return alt_ticks_per_second(); // через какое время снова вызвать функцию
}

int main() {
    volatile int leds=0X01; // первый светодиод включён
    static alt_alarm alarm; // Объявление переменной таймера. static — чтобы она сохранялась после выхода из блока
    IOWR_ALTERA_AVALON_PIO_DATA(LED_BASE,0x00);
    // функция alt_alarm_start запускает аппаратный таймер
    if (alt_alarm_start(&alarm, 					// указатель на структуру таймера
    					alt_ticks_per_second(),		// период срабатывания (1 секунда)
						my_alarm_callback, 			// функция, вызываемая при срабатывании таймера
						(void*)&leds) < 0)			//
    alt_printf("No system clock available\n");
    else alt_printf("Процессор Nios II запущен!\n");
    while (1){
    	;
    }
    return 0;
}
